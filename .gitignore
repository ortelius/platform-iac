# Terraform directories and files
.terraform/             # Local cache of modules and providers
*.tfstate               # Terraform state files (sensitive)
*.tfstate.*             # Backup state files
crash.log               # Crash logs generated by Terraform
override.tf             # Local overrides
override.tf.json        # Local overrides in JSON
*.tfplan                # Terraform plan output files (binary)
*.tfvars                # Variable files with sensitive data
*.tfvars.json           # JSON variable files
*.bak

# Ignore CLI configuration
.terraformrc
terraform.rc

# Ignore editor or OS files
*.swp                   # Vim swap files
*.bak                   # Backup files
*.tmp                   # Temporary files
.DS_Store               # macOS
Thumbs.db               # Windows

# Optional: lock file (commit if you want version consistency)
# terraform.lock.hcl    # Keep this commented if you want to commit it
